# =============================================
# MQ Player — Environment Variables
# =============================================

# Database (Vercel Postgres — free, built into Vercel)
DATABASE_URL="postgres://default:xxx@xxx-postgres.render-1.com.vercel-storage.com/verceldb?sslmode=require"
POSTGRES_URL_NON_POOLING="postgres://default:xxx@xxx-postgres.render-1.com.vercel-storage.com/verceldb?sslmode=require"

# Upload directory (Vercel only supports /tmp)
UPLOADS_DIR="/tmp/uploads"

# ── Brevo (Sendinblue) — Email delivery (FREE, 300/day, no domain needed) ──
# 1. Sign up at https://www.brevo.com
# 2. Settings → SMTP & API → Generate a new API key → paste below:
BREVO_API_KEY="xkeysib-xxxxxxxxxxxxxxxxxxxx"
# 3. Settings → Senders → Add a sender → verify via email → paste below:
BREVO_SENDER_EMAIL="your-verified@email.com"
# 4. (Optional) Custom sender name:
BREVO_SENDER_NAME="MQ Player"

# Admin emails (comma-separated, for admin panel access)
NEXT_PUBLIC_ADMIN_EMAILS="killkin.hi@gmail.com"

# JWT Secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET="CHANGE_ME_to_a_random_32_char_string"

# ── Telegram Bot (for Telegram-based auth) ──
# 1. Create a bot via @BotFather on Telegram
# 2. Get the bot token and paste below:
TELEGRAM_BOT_TOKEN=""
# 3. (Optional) Bot username for display in UI:
TELEGRAM_BOT_NAME=""

# ── Spotify API (search, full playback via Web Playback SDK) ──
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app → get Client ID and Client Secret
# 3. Set Redirect URI: https://your-domain.com/api/spotify/auth/callback
# 4. Paste below:
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Base URL (needed for Spotify OAuth callback redirect)
# On Vercel this is set automatically; for local dev use http://localhost:3000
NEXT_PUBLIC_BASE_URL=""
